{
  "expo": {
    "name": "Rondas Protemaxi",
    "slug": "rondas-protemaxi",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "platforms": [
      "android"
    ],
    "android": {
      "package": "com.protemaxi.rondas",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "La app registra tu ubicación durante la ronda para validar el recorrido.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "La cámara se usa para escanear los códigos QR de los checkpoints."
        }
      ],
      "@maplibre/maplibre-react-native",
      "expo-asset"
    ]
  }
}

# Database (inside Docker use host "postgres"; from the host machine use "localhost")
DATABASE_URL=postgresql+psycopg2://rondas:rondas@postgres:5432/rondas

# Redis (inside Docker use host "redis"; from the host machine use "localhost")
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-dev-too
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Analysis thresholds (business rules — never hardcode these)
WALK_ACCEL_THRESHOLD_MPS2=1.2
INACTIVITY_WINDOW_MIN=5
INACTIVITY_STILL_RATIO=0.8
ROUTE_FRECHET_THRESHOLD_M=100
IMPOSSIBLE_SPEED_MPS=3.5
IMPOSSIBLE_SPEED_MIN_DURATION_S=30
SCAN_MAX_FIX_AGE_S=30
SCAN_MAX_ACCURACY_M=50
PERFORMANCE_DECLINE_RATIO=0.3
FRAUD_SEVERITY_MEDIUM_RATIO=2.0
FRAUD_SEVERITY_HIGH_RATIO=5.0
